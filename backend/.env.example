PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=shop_system

# Must be at least 32 characters and NOT the placeholder below
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE-THIS-WITH-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for production: ALLOWED_ORIGINS=http://192.168.1.100:3001
ALLOWED_ORIGINS=http://localhost:3001
